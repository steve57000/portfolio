---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { profile, skills, journey, featuredProjects } from '../data/portfolioData';
import SeoHead from '../components/SeoHead.astro';
import '../styles/global.css';
import { withBase } from '../utils/paths';
---
<!doctype html><html lang="fr"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width"/><SeoHead title="CV — Steve Bell" description="CV synthétique de Steve Bell : développeur fullstack Java Angular et Data Analyst junior." canonical="https://steve57000.github.io/portfolio/cv/" /></head><body><Header /><main class="cv-page"><section class="section"><p class="eyebrow">CV</p><h1>{profile.name}</h1><p class="hero__lead">{profile.title}</p><p>{profile.summary}</p><div class="hero__actions"><a class="button" href={`mailto:${profile.email}`}>{profile.email}</a><a class="button button--ghost" href={profile.links.github}>GitHub</a></div></section><section class="section"><SectionHeader title="Projets représentatifs"/><div class="cv-list">{featuredProjects.map((project) => <article><h2>{project.title}</h2><p>{project.summary}</p><p><strong>Stack :</strong> {project.stack.join(', ')}</p></article>)}</div></section><section class="section"><SectionHeader title="Compétences"/><div class="skill-grid">{skills.map((group) => <article><h2>{group.group}</h2><ul>{group.items.map((item) => <li>{item}</li>)}</ul></article>)}</div></section><section class="section"><SectionHeader title="Parcours"/><ol class="timeline">{journey.map((step) => <li><span>{step.period}</span><h2>{step.title}</h2><p>{step.text}</p></li>)}</ol></section></main><Footer /><script src={withBase('scripts/main.js')} defer></script></body></html>
